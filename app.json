{
  "expo": {
    "name": "roadsense-app",
    "slug": "roadsense-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mughilr.roadsenseapp",
      "config": {
        "googleMapsApiKey": "AIzaSyATeJx7qeJL9h5lGaoqADeXRhms_ij_XzI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RoadSense needs your location to detect and map potholes.",
        "NSLocationAlwaysUsageDescription": "RoadSense needs background location to detect potholes while driving."
      }
    },
    "android": {
      "package": "com.mughilr.roadsenseapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyATeJx7qeJL9h5lGaoqADeXRhms_ij_XzI"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RoadSense to use your location to detect potholes."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00f3ff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f03bb0f3-8acc-4e25-ac91-eb269761cde8"
      }
    }
  }
}
